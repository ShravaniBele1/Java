package java1;

public class LCM_GCD {

	public static int GCD(int a, int b) {
		
		while(b != 0) {
			int temp = b ;
			b = a % b ;
			a = temp ;
		}
		return a;
	}
	
	public static int LCM(int a, int b) {
		return (a/GCD(a,b))*b;
	}
	
	public static void main(String[] args) {
		int a = 18 ;
		int b = 12 ;
		
		System.out.println("GCD : "+GCD(a, b));
		System.out.println("LCM : "+LCM(a, b));
	}

}
