package java1;

public class Equilibrium_Index {

	public static int Index(int arr[]) {
		
		int lsum = 0 ;
		int totalsum = 0 ;
		
		for(int num : arr) {
			totalsum +=	num;
		}
		
		for(int i = 0; i< arr.length ;i++) {
			totalsum -= arr[i];
			
			if(lsum == totalsum) {
				return i ;
			}
			
			lsum += arr[i] ;
		}
		return -1;
	}
	
	public static void main(String[] args) {
		
		int arr[] = {-7, 1, 5, 2, -4, 3, 0};
		
		System.out.print(Index(arr));
	}

}
