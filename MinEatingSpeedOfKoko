class Solution {
    public int minEatingSpeed(int[] piles, int h) {
        
        int low = 1;
        int high = findMax(piles);
        
        while( low <= high){

            int mid = low + (high - low)/2 ;

            long hours = calculateHours(piles, mid);

            if(hours <= h)
                high = mid -1 ;
            else
                low = mid + 1 ;
        }
        return low ;
    }

    public static int findMax(int[] piles){
        int max = piles[0];

        for(int pile : piles){
            if(pile > max)
                max = pile ;
        }
        return max;
    }

    public static long calculateHours(int[] piles , int k){

        long totalHours = 0;

        for(int pile : piles){

            totalHours += (int)Math.ceil((double)pile/k);
        }

        return totalHours ;
    }
}
